# musicpipe — unified Apple Music → tagger → streamer stack
# Copy to .env and fill in the values:  cp .env.example .env

# ── Filesystem ──────────────────────────────────────────────────────────────
# Where the music lives. MUSIC_ROOT is the parent; the others are its children.
# Incoming/ = raw gamdl drops, Library/ = beets-tagged (served by Navidrome),
# NavidromeData/ = Navidrome's own DB/cache. These dirs must be owned by PUID:PGID.
MUSIC_ROOT=/srv/navidrome
INCOMING_DIR=/srv/navidrome/Incoming
LIBRARY_DIR=/srv/navidrome/Library
NAVIDROME_DATA=/srv/navidrome/NavidromeData

# ── Runtime user ────────────────────────────────────────────────────────────
# Must match the ownership of the directories above and the uid/gid hard-coded
# in gamdl/Dockerfile and gamdl-ui/Dockerfile (1000/1001).
PUID=1000
PGID=1001
TZ=Europe/London

# ── Ports ───────────────────────────────────────────────────────────────────
NAVIDROME_PORT=4533
GAMDL_UI_PORT=4150

# ── Tuning ──────────────────────────────────────────────────────────────────
# auto-import sidecar loop interval (seconds)
AUTO_IMPORT_INTERVAL=300
# gamdl-ui library indexer sweep interval (seconds) — full walk of Incoming+Library
INDEXER_INTERVAL=120

# ── Navidrome ───────────────────────────────────────────────────────────────
# Credentials used by gamdl-ui to trigger Subsonic rescans (create this user in
# Navidrome after first launch).
NAVIDROME_USER=admin
NAVIDROME_PASS=changeme
# Public/browser-facing Navidrome URL, used for "open in Navidrome" deep links.
NAVIDROME_PUBLIC_URL=http://localhost:4533

# ── Last.fm (optional) ──────────────────────────────────────────────────────
# Powers Navidrome getSimilarSongs2 / getArtistInfo2 / getTopSongs.
# Free API account: https://www.last.fm/api/account/create (only an app name needed).
# Leave blank to disable.
ND_LASTFM_APIKEY=
ND_LASTFM_SECRET=

# ── Track-level pre-filter (advanced) ───────────────────────────────────────
# When 1, the UI runner and cron run.sh expand each watchlist URL via the Apple
# Music API and hand gamdl only the per-track URLs it doesn't already hold.
# When 0 (default), URL-level skip only (per-file skip relies on Incoming hardlinks).
USE_TRACK_EXPANSION=0
